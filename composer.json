{
    "name": "otter-tecno/backend-slim",
    "version": "1.0.0",
    "keywords": [
        "microframework"
    ],
    "authors": [
        {
            "name": "rogeroe",
            "homepage": "https://github.com/rogeroe"
        }
    ],
    "license": "GNU v3.0",
    "require": {
        "php": "^8.2",
        "slim/slim": "4.*",
        "slim/psr7": "^1.8",
        "nyholm/psr7": "^1.8",
        "nyholm/psr7-server": "^1.1",
        "guzzlehttp/psr7": "^2",
        "laminas/laminas-diactoros": "^3.8",
        "vlucas/phpdotenv": "^5.6",
        "symfony/validator": "^7.4",
        "zircote/swagger-php": "^6.0",
        "monolog/monolog": "^3.10",
        "firebase/php-jwt": "^7.0",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S 0.0.0.0:8080 -t public public/index.php",
        "swagger": "php -S 0.0.0.0:8081 -t public public/swagger.php"
    },
    "config": {
        "process-timeout": 0
    }
}